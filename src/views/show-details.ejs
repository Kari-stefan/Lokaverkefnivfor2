<%- include('partials/header') %>

  <section class="showdetail">
    <img src="<%= show.image_url %>" alt="<%= show.title %>">
    <div class="showdetailinfo">
      <h1>
        <%= show.title %> (<%= show.year %>)
      </h1>
      <div class="showmeta">
        <span class="badge">
          <%= show.genre %>
        </span>
        <span class="badge">
          <%= show.seasons %> season<%= show.seasons !==1 ? 's' : '' %>
        </span>
      </div>
      <p>
        <%= show.description %>
      </p>
      <a href="/" class="buttonback">← Til baka</a>
    </div>
  </section>

  <section class="reviews-section">
    <h2>Umsagnir</h2>

    <% if (!reviews || reviews.length===0) { %>
      <p class="noreviews">Engar umsagnir ennþá.</p>
      <% } else { %>
        <div class="reviews-container">
          <% reviews.forEach(review=> { %>
            <div class="reviewcard">
              <div class="reviewheader">
                <strong class="reviewauthor">
                  <%= review.author %>
                </strong>

                <span class="reviewrating">
                  ⭐ <%= review.rating %>/10
                </span>
              </div>

              <p class="reviewcomment">
                <%= review.comment %>
              </p>

              <small class="reviewdate">
                <%= new Date(review.created_at).toLocaleDateString('is-IS') %>
              </small>
            </div>
            <% }) %>
        </div>
        <% } %>
  </section>

  <section class="reviewformsection">
    <h2>Skrifa umsögn</h2>
    <form class="reviewform" action="/show/<%= show.id %>/review" method="POST">
      <div class="reviewform__group">
        <label for="author">Nafn þitt</label>
        <input type="text" id="author" name="author" placeholder="t.d. Hjörvar" required maxlength="100">
      </div>

      <div class="reviewform__group">
        <label for="rating">Einkunn (1-10)</label>
        <div class="ratinginput">
          <input type="range" id="rating" name="rating" min="1" max="10" value="5"
            oninput="document.getElementById('ratingdisplay').textContent = this.value">
          <span class="ratingdisplay" id="ratingdisplay">5</span>
        </div>
      </div>

      <div class="reviewform__group">
        <label for="comment">Umsögn</label>
        <textarea id="comment" name="comment" rows="4" placeholder="Hvað finnst þér um þáttinn?" required
          maxlength="1000"></textarea>
      </div>

      <button type="submit" class="btnsubmit">gera umsögn</button>
    </form>
  </section>

  <%- include('partials/footer') %>