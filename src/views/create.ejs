<%- include('partials/header') %>

  <div class="pagehero">
    <h1>Bæta við þætti</h1>
    <p>Skráðu nýjan sjónvarpsþátt í gagnagrunninn.</p>
  </div>

  <div class="formcontainer">
    <form action="/create" method="POST" class="authform">
      <div class="formgroup">
        <label for="title">Nafn þáttar *</label>
        <input type="text" id="title" name="title" required>
      </div>

      <div class="formrow">
        <div class="formgroup">
          <label for="year">Útgáfuár *</label>
          <input type="number" id="year" name="year" min="1950" required>
        </div>

        <div class="formgroup">
          <label for="seasons">Fjöldi sería</label>
          <input type="number" id="seasons" name="seasons" min="1">
        </div>
      </div>

      <div class="formgroup">
        <label for="genre">Tegund (Genre)</label>
        <input type="text" id="genre" name="genre">
      </div>

      <div class="formgroup">
        <label for="image_url">Vefslóð á mynd (valfrjálst)</label>
        <input type="url" id="image_url" name="image_url" placeholder="https://...">
      </div>

      <div class="formgroup">
        <label for="description">Lýsing</label>
        <textarea id="description" name="description" rows="4"></textarea>
      </div>

      <button type="submit" class="btn btnsubmit">Bæta við</button>
    </form>
  </div>

  <%- include('partials/footer') %>